# ============================================================
#  DiscBot — Configuration (.env.example)
#  Copy this file to .env and fill in your values
#  NEVER commit the actual .env file to version control!
# ============================================================

# ------------------------------------------------------------
# DISCORD BOT (Required)
# ------------------------------------------------------------
# Get your bot token from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Optional: Guild ID to restrict bot to a single server
# Leave empty or 0 to allow all servers
GUILD_ID=0

# Optional: Channel ID where music commands work (0 = all channels)
MUSIC_CHANNEL_ID=0

# Optional: Voice channel ID for 24/7 auto-join mode
MUSIC_VOICE_CHANNEL_ID=0

# Bot Owner ID (super-admin, bypasses all checks)
# Get by enabling Developer Mode in Discord, right-click your user → Copy ID
OWNER_ID=0

# ------------------------------------------------------------
# LAVALINK SERVER (Required)
# ------------------------------------------------------------
# Default values for local Lavalink v4 instance
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=12333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Enable YouTube cookies for age-restricted/region-locked videos
# Place ytcookies.txt (Netscape format) in project root or lavalink folder
YOUTUBE_COOKIES_ENABLED=true

# ------------------------------------------------------------
# SPOTIFY API (Optional - for Spotify URL support)
# ------------------------------------------------------------
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# SQLite (default, local file) - no setup required
# DATABASE_URL=sqlite+aiosqlite:///data/discbot.db

# PostgreSQL (production) - uncomment and set if using PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/discbot

# SQLite fallback path (used when DATABASE_URL is not set)
DATABASE_PATH=data/discbot.db

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ------------------------------------------------------------
# WEB DASHBOARD (FastAPI)
# ------------------------------------------------------------
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=18080

# IMPORTANT: Generate a strong random secret key!
# python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_SECRET_KEY=change_me_to_a_random_secret_key_min_32_chars

# CORS origins for dashboard (comma-separated)
# Default allows localhost access + frontend dev server
DASHBOARD_CORS_ORIGINS=http://localhost:18080,http://127.0.0.1:18080,http://localhost:5173

# Frontend API URL (for production build)
# In dev, Vite proxies /api to dashboard; in prod, set to your domain
# VITE_API_URL=https://your-domain.com

# ------------------------------------------------------------
# BRANDING & LINKS (Shown in /help and dashboard)
# ------------------------------------------------------------
SUPPORT_SERVER_URL=https://discord.gg/jbjEpqwNn
DISCORD_INVITE_URL=https://discord.gg/jbjEpqwNn
BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_CLIENT_ID&scope=bot%20applications.commands&permissions=277062449408
WEBSITE_URL=https://github.com/devilforcex/discbot
MADE_BY_TEXT=Made with ❤️ by Steel

# ------------------------------------------------------------
# ADVANCED / OPTIONAL
# ------------------------------------------------------------
# Lavalink node name (for multi-node setups)
# LAVALINK_NODE_NAME=local

# Lavalink session resume timeout (seconds)
# LAVALINK_RESUME_TIMEOUT=60

# YouTube Music cookies file path (if not in default location)
# YTMUSIC_COOKIES_FILE=ytmusic_cookies.json

# Enable Lavalink health endpoint on dashboard
# LAVALINK_HEALTH_ENDPOINT=true