# Discord Bot Configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# Discord Bot Token (required)
# Get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Guild Restriction (required)
# The bot will only respond to commands in this guild
GUILD_ID=1074037877899542538

# Music Channel Restriction (required)
# Music commands may only be used in this channel
# Exceptions: !help, !ping, !whoami, !requestaccess
MUSIC_CHANNEL_ID=1097945134630445227

# Bot Owner (super-admin, bypasses all permission checks)
OWNER_ID=954887574248374322

# Lavalink Server Configuration (required)
# Default values for local Lavalink instance
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Spotify API Credentials (optional, for Spotify URL support)
# Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Database Configuration
# Path to SQLite database file (relative to project root)
DATABASE_PATH=data/musicbot.db

# Logging Configuration
# Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Web Dashboard Configuration (optional)
# Set DASHBOARD_ENABLED=false to disable the dashboard
DASHBOARD_ENABLED=false
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_SECRET_KEY=change_me_to_a_random_secret_key