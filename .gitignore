# Environment
.env

# Database
data/
*.db

# Logs
logs/
*.log
bot/logs/

# Lavalink
# Do NOT ignore these - required for Docker build:
# Lavalink.jar, application.yml, plugins/

# Ignore Lavalink runtime files (logs, cookies, local scripts)
lavalink/logs/
lavalink/lavalink.log
lavalink/*.bak
lavalink/run_lavalink.bat
lavalink/ytcookies.txt
# Root plugins/ is a duplicate of lavalink/plugins/
/plugins/
*.yml.bak

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
venv/
.venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Dashboard runtime cache only (keep templates/static in repo)
# bot/dashboard/static/
# bot/dashboard/templates/
# Allow our refactored lavalink package (not the Lavalink server folder)
!bot/music/lavalink/
!bot/music/lavalink/**
# Re-ignore pycache inside allowed package
bot/music/lavalink/__pycache__/
**/__pycache__/
__pycache__/

# Windows installer build output
scripts/windows/Output/
scripts/windows/*.exe
scripts/windows/*.ico
# Profile (PowerShell may leave this around)
*.ps1.bak

# Local scratch / generated artifacts that must not block updates
generated-page.html
/update.bat

