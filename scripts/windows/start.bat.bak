@echo off
REM ============================================================
REM  DiscBot — Start Lavalink + Discord Bot
REM  ------------------------------------------------------------
REM  Lavalink lives in E:\discbot\lavalink\ with its own config & plugins.
REM  The Discord bot lives in E:\discbot\ (root).
REM  Opens two console windows: one for Lavalink, one for the bot.
REM ============================================================
setlocal
chcp 65001 >nul
title DiscBot Launcher

cd /d "E:\discbot" 2>nul
if errorlevel 1 (
    echo  ❌ E:\discbot does not exist or is not accessible. Run install.ps1 first.
    pause
    exit /b 1
)

echo  🎵 DiscBot @ %CD%
echo.

if not exist ".env" (
    echo  ❌ .env not found. Run setup.bat first.
    pause
    exit /b 1
)
if not exist ".venv\Scripts\python.exe" (
    echo  ❌ .venv not found. Run setup.bat first.
    pause
    exit /b 1
)
if not exist "lavalink\Lavalink.jar" (
    echo  ❌ lavalink\Lavalink.jar not found. Run setup.bat to download it,
    echo     or place Lavalink.jar in E:\discbot\lavalink\.
    pause
    exit /b 1
)
if not exist "lavalink\application.yml" (
    echo  ❌ lavalink\application.yml not found. Bot cannot start without it.
    pause
    exit /b 1
)
if not exist "lavalink\plugins\youtube-plugin-1.18.0.jar" (
    echo  ⚠️  lavalink\plugins\youtube-plugin-1.18.0.jar not found.
    echo     YouTube playback may not work correctly.
    timeout /t 3 /nobreak >nul
)

echo  Starting Lavalink from lavalink/ (new window)...
start "DiscBot — Lavalink" cmd /k "cd /d ""%CD%\lavalink"" && run_lavalink.bat"

echo  Waiting for Lavalink to boot (10s)...
timeout /t 10 /nobreak >nul

echo  Starting bot (new window)...
start "DiscBot — Bot" cmd /k "cd /d ""%CD%"" && .venv\Scripts\python.exe -m bot.main"

echo.
echo  ✅ Both processes launched in separate windows.
echo     - Lavalink: lavalink\ directory (port 12333)
echo     - Bot:      %CD%
echo     Close the windows (or run stop.bat) to shut them down.
echo.
endlocal
exit /b 0
